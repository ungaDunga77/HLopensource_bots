# Hyperliquid Testnet Configuration
# NEVER use mainnet keys in this project

# === Generic (osbots framework) ===
# Your testnet private key (without 0x prefix)
HL_PRIVATE_KEY=
# Must remain true — do not change
HL_TESTNET=true
# Testnet API endpoint
HL_API_URL=https://api.hyperliquid-testnet.xyz

# === Chainstack Grid Bot ===
# Private key with 0x prefix (bot validates 0x + 64 hex chars)
HYPERLIQUID_TESTNET_PRIVATE_KEY=
# Must remain true
HYPERLIQUID_TESTNET=true

# === Hummingbot ===
# Password that encrypts Hummingbot's conf/connectors/*.yml and .password_verification.
# Set any passphrase; used only locally inside the testnet container.
CONFIG_PASSWORD=
# (Optional) Arbitrum wallet address for arb_wallet mode. If unset, derived from
# HYPERLIQUID_TESTNET_PRIVATE_KEY at seed time.
HL_TESTNET_ADDRESS=
