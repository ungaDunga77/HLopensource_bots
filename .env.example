# Testnet API endpoint
HL_API_URL=https://api.hyperliquid-testnet.xyz

# === Chainstack Grid Bot ===
# Private key with 0x prefix (bot validates 0x + 64 hex chars)
HYPERLIQUID_TESTNET_PRIVATE_KEY=
# Must remain true
HYPERLIQUID_TESTNET=true
